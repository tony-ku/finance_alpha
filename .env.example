# Copy this file to .env and fill in values. All entries are optional for Phase 1.

# --- IMAP (Phase 2) -------------------------------------------------------
# ProtonMail users: start ProtonMail Bridge; Bridge exposes localhost IMAP.
# Get the Bridge-generated password from the Bridge app (not your account password).
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_USE_SSL=false
IMAP_USER=you@proton.me
IMAP_APP_PASSWORD=

# --- API keys (Phase 3) ---------------------------------------------------
# Financial Modeling Prep free key: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# Finnhub free key: https://finnhub.io/register
FINNHUB_API_KEY=

# --- SMTP for email alerts (Phase 4, optional) ---------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
